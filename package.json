{
  "name": "showjson",
  "version": "0.1.0",
  "description": "A fast, local-first JSON quick viewer for desktop.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
