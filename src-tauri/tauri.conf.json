{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShowJSON",
  "version": "1.0.0",
  "identifier": "com.peacetool.showjson",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ShowJSON",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Instantly inspect JSON copied from any application.",
    "longDescription": "ShowJSON is a fast, local-first desktop JSON viewer triggered from the clipboard with a global shortcut.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
